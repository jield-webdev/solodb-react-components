{
  "name": "@jield/solodb-react-components",
  "version": "1.1.4",
  "type": "module",
  "repository": "jield-webdev/solodb-react-components",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "dev": "cd example && yarn dev",
    "example:install": "cd example && yarn install",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@jield/solodb-typescript-core": "link:../solodb-typescript-core/",
    "@testing-library/dom": "^10.4.1",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.1",
    "qrcode.react": "^4.2.0",
    "react-bootstrap": "^2.10.10",
    "react-dropzone": "^15.0.0",
    "react-google-charts": "^5.2.1",
    "react-hook-form": "^7.72.1",
    "react-intersection-observer": "^10.0.3",
    "react-markdown": "^10.1.0",
    "react-select": "^5.10.2",
    "yet-another-react-lightbox": "^3.31.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.90",
    "@tanstack/react-table": "^8.21",
    "axios": "^1.13.2",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7.9"
  },
  "devDependencies": {
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@tanstack/react-query": "~5.99.0",
    "@tanstack/react-query-devtools": "~5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "axios": "^1.15.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "prop-types": "^15.8.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "packageManager": "yarn@4.13.0"
}
